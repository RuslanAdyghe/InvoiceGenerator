{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InvoiceMetadata",
  "type": "object",
  "required": [
    "ProfileID",
    "IssueDate",
    "DueDate",
    "OrderReference",
    "Delivery",
    "PaymentMeans",
    "Supplier",
    "Customer"
  ],
  "properties": {
    "InvoiceID": {
      "type": "string",
      "description": "Unique invoice identifier (generated by platform)",
      "readOnly": true
    },
    "ProfileID": {
      "type": "string",
      "description": "UBL profile identifier"
    },
    "IssueDate": {
      "type": "string",
      "format": "date",
      "description": "Date the invoice was issued"
    },
    "DueDate": {
      "type": "string",
      "format": "date",
      "description": "Date payment is due"
    },
    "OrderReference": {
      "type": "object",
      "required": ["ID"],
      "properties": {
        "ID": {
          "type": "string",
          "description": "Reference to the related order"
        }
      }
    },
    "Delivery": {
      "type": "object",
      "required": ["ActualDeliveryDate"],
      "properties": {
        "ActualDeliveryDate": {
          "type": "string",
          "format": "date",
          "description": "Date goods/services were delivered"
        },
        "ActualDeliveryTime": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):([0-5]\\d):([0-5]\\d)$",
          "description": "Time of delivery in HH:MM:SS format"
        }
      }
    },
    "PaymentMeans": {
      "type": "object",
      "required": ["PaymentMeansCode", "PayeeFinancialAccount"],
      "properties": {
        "PaymentMeansCode": {
          "type": "string",
          "description": "Code representing payment method (e.g., bank transfer)"
        },
        "PaymentDueDate": {
          "type": "string",
          "format": "date",
          "description": "Optional override for due date"
        },
        "PayeeFinancialAccount": {
          "type": "object",
          "required": ["ID", "Name", "Currency"],
          "properties": {
            "ID": {
              "type": "string",
              "description": "Bank account number"
            },
            "Name": {
              "type": "string",
              "description": "Account holder name"
            },
            "Currency": {
              "type": "string",
              "description": "ISO currency code"
            }
          }
        }
      }
    },
    "Supplier": {
      "type": "object",
      "required": ["Name"],
      "properties": {
        "Name": {
          "type": "string",
          "description": "Supplier (seller) name"
        },
        "ID": {
          "type": "string",
          "description": "Optional supplier identifier"
        }
      }
    },
    "Customer": {
      "type": "object",
      "required": ["Name"],
      "properties": {
        "Name": {
          "type": "string",
          "description": "Customer (payer) name"
        },
        "ID": {
          "type": "string",
          "description": "Optional customer identifier"
        }
      }
    }
  }
}