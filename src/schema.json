{
  "title": "InvoiceMetadata",
  "type": "object",
  "required": [
    "ProfileID",
    "IssueDate",
    "DueDate",
    "OrderReference",
    "Delivery",
    "LegalMonetaryTotal",
    "PaymentMeans",
    "Supplier",
    "Customer"
  ],
  "properties": {
    "InvoiceID": {
      "type": "string",
      "description": "Unique invoice identifier (generated by platform)",
      "readOnly": true
    },
    "ProfileID": {
      "type": "string",
      "description": "UBL profile identifier"
    },
    "IssueDate": {
      "type": "string",
      "format": "date",
      "description": "Date the invoice was issued"
    },
    "DueDate": {
      "type": "string",
      "format": "date",
      "description": "Date payment is due"
    },
    "InvoiceTypeCode": {
      "type": "string",
      "description": "Invoice type code"
    },
    "DocumentCurrencyCode": {
      "type": "string",
      "description": "Invoice currency code"
    },
    "OrderReference": {
      "type": "object",
      "required": ["ID"],
      "properties": {
        "ID": {
          "type": "string",
          "description": "Reference to the related order"
        }
      }
    },
    "Delivery": {
      "type": "object",
      "required": ["ActualDeliveryDate"],
      "properties": {
        "ActualDeliveryDate": {
          "type": "string",
          "format": "date",
          "description": "Date goods/services were delivered"
        },
        "ActualDeliveryTime": {
          "type": "string",
          "pattern": "^([01]\\d|2[0-3]):([0-5]\\d):([0-5]\\d)$",
          "description": "Time of delivery in HH:MM:SS format"
        }
      }
    },
    "PaymentMeans": {
      "type": "object",
      "required": ["PaymentMeansCode", "PayeeFinancialAccount"],
      "properties": {
        "PaymentMeansCode": {
          "type": "string",
          "description": "Code representing payment method (e.g., bank transfer)"
        },
        "PaymentDueDate": {
          "type": "string",
          "format": "date",
          "description": "Optional override for due date"
        },
        "PayeeFinancialAccount": {
          "type": "object",
          "required": ["ID", "Name"],
          "properties": {
            "ID": {
              "type": "string",
              "description": "Bank account number"
            },
            "Name": {
              "type": "string",
              "description": "Account holder name"
            }
          }
        }
      }
    },
    "LegalMonetaryTotal": {
      "type": "object",
      "required": [
        "LineExtensionAmount",
        "TaxExclusiveAmount",
        "TaxInclusiveAmount",
        "PayableAmount"
      ],
      "properties": {
        "LineExtensionAmount": {
          "type": "number",
          "description": "Sum of all invoice line amounts before tax"
        },
        "TaxExclusiveAmount": {
          "type": "number",
          "description": "Total amount excluding tax"
        },
        "TaxInclusiveAmount": {
          "type": "number",
          "description": "Total amount including tax"
        },
        "AllowanceTotalAmount": {
          "type": "number",
          "description": "Total discounts applied (optional)"
        },
        "ChargeTotalAmount": {
          "type": "number",
          "description": "Total extra charges applied (optional)"
        },
        "PrepaidAmount": {
          "type": "number",
          "description": "Amount already paid upfront (optional)"
        },
        "PayableAmount": {
          "type": "number",
          "description": "Final amount due for payment"
        }
      }
    },
    "Supplier": {
      "type": "object",
      "required": ["Name", "PostalAddress"],
      "properties": {
        "Name": { "type": "string", "description": "Supplier legal name" },
        "TradingName": {
          "type": "string",
          "description": "Supplier trading name"
        },
        "PostalAddress": {
          "type": "object",
          "required": ["Country"],
          "properties": {
            "StreetName": { "type": "string" },
            "AdditionalStreetName": { "type": "string" },
            "CityName": { "type": "string" },
            "PostalZone": { "type": "string" },
            "CountrySubentity": { "type": "string" },
            "Country": {
              "type": "string",
              "description": "Country code - required per IBR-009"
            }
          }
        },
        "Contact": {
          "type": "object",
          "properties": {
            "Name": { "type": "string" },
            "Telephone": { "type": "string" },
            "ElectronicMail": { "type": "string" }
          }
        }
      }
    },
    "Customer": {
      "type": "object",
      "required": ["Name", "PostalAddress"],
      "properties": {
        "Name": { "type": "string", "description": "Customer legal name" },
        "TradingName": {
          "type": "string",
          "description": "Customer trading name"
        },
        "PostalAddress": {
          "type": "object",
          "required": ["Country"],
          "properties": {
            "StreetName": { "type": "string" },
            "AdditionalStreetName": { "type": "string" },
            "CityName": { "type": "string" },
            "PostalZone": { "type": "string" },
            "CountrySubentity": { "type": "string" },
            "Country": {
              "type": "string",
              "description": "Country code - required per IBR-009"
            }
          }
        },
        "Contact": {
          "type": "object",
          "properties": {
            "Name": { "type": "string" },
            "Telephone": { "type": "string" },
            "ElectronicMail": { "type": "string" }
          }
        }
      }
    }
  }
}
