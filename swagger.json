{
  "openapi": "3.0.0",
  "info": {
    "title": "Invoice Generator API",
    "version": "1.0.0",
    "description": "API for generating UBL XML invoices from structured input data"
  },
  "servers": [
    {
      "url": "http://3.106.79.128:3000",
      "description": "Production server"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Auth",
      "description": "User authentication and registration"
    },
    {
      "name": "Invoices",
      "description": "Invoice creation, retrieval, transformation and validation"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/signup": {
      "post": {
        "tags": ["Auth"],
        "security": [],
        "summary": "Sign up",
        "description": "Creates a new user account and returns a JWT token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SignupRequest"
              },
              "example": {
                "email": "aaron@stashcorp.com",
                "password": "password123",
                "companyName": "Stash Corp"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "400": {
            "description": "Email already in use or missing required fields"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "security": [],
        "summary": "Login",
        "description": "Logs in an existing user and returns a JWT token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              },
              "example": {
                "email": "aaron@stashcorp.com",
                "password": "password123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuthResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid email or password"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    },
    "/invoices": {
      "post": {
        "tags": ["Invoices"],
        "summary": "Create Invoice",
        "description": "Creates a new structured invoice from input data",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvoiceRequest"
              },
              "example": {
                "userId": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8",
                "invoiceData": {
                  "ProfileID": "urn:fdc:peppol.eu:2017:poacc:billing:01:1.0",
                  "IssueDate": "2024-01-15",
                  "DueDate": "2024-02-15",
                  "OrderReference": {
                    "ID": "ORD-001"
                  },
                  "Delivery": {
                    "ActualDeliveryDate": "2024-01-14",
                    "ActualDeliveryTime": "14:30:00"
                  },
                  "PaymentMeans": {
                    "PaymentMeansCode": "30",
                    "PaymentDueDate": "2024-02-15",
                    "PayeeFinancialAccount": {
                      "ID": "GB29NWBK60161331926819",
                      "Name": "Stash Corp",
                      "Currency": "AUD"
                    }
                  },
                  "Supplier": {
                    "Name": "Stash Corp",
                    "ID": "SUP-001"
                  },
                  "Customer": {
                    "Name": "Client Ltd",
                    "ID": "CUST-001"
                  },
                  "LegalMonetaryTotal": {
                    "Currency": "AUD",
                    "LineExtensionAmount": 1436.5,
                    "TaxExclusiveAmount": 1436.5,
                    "TaxInclusiveAmount": 1729,
                    "AllowanceTotalAmount": 100,
                    "ChargeTotalAmount": 100,
                    "PrepaidAmount": 1000,
                    "PayableAmount": 729
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invoice successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateInvoiceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "get": {
        "tags": ["Invoices"],
        "summary": "List invoices",
        "description": "Retrieve invoices with optional filtering",
        "parameters": [
          {
            "name": "customerId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orderId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of invoices",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceList"
                }
              }
            }
          }
        }
      }
    },
    "/invoices/{invoiceId}": {
      "get": {
        "tags": ["Invoices"],
        "summary": "Retrieve invoice",
        "description": "Retrieves a previously created invoice by its unique ID, returning all stored invoice data.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac",
            "description": "Unique identifier for the invoice"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceResponse"
                }
              }
            }
          },
          "404": {
            "description": "Invoice not found"
          },
          "500": {
            "description": "System failure"
          }
        }
      }
    },
    "/invoices/{invoiceId}/validate": {
      "post": {
        "tags": ["Invoices"],
        "summary": "Validate invoice",
        "description": "Validates the generated UBL invoice document against the required UBL validation rules and schema to check if it is compliant.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac",
            "description": "Unique identifier for the invoice"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateInvoiceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invoice has not been transformed yet"
          },
          "404": {
            "description": "InvoiceId does not exist"
          },
          "500": {
            "description": "Unexpected system failure"
          }
        }
      }
    },
    "/invoices/{invoiceId}/transform": {
      "post": {
        "tags": ["Invoices"],
        "summary": "Transform invoice",
        "description": "Transforms a previously created structured invoice into a UBL XML invoice document.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac",
            "description": "Unique identifier for the invoice"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice successfully transformed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransformInvoiceResponse"
                }
              }
            }
          },
          "404": {
            "description": "InvoiceId does not exist"
          },
          "500": {
            "description": "Unexpected system failure"
          }
        }
      }
    },
    "/invoices/{invoiceId}/download": {
      "get": {
        "tags": ["Invoices"],
        "summary": "Download invoice XML",
        "description": "Downloads the transformed UBL XML invoice document as a file.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac",
            "description": "Unique identifier for the invoice"
          }
        ],
        "responses": {
          "200": {
            "description": "UBL XML invoice document",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "object",
                  "xml": {
                    "name": "Invoice",
                    "namespace": "urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
                  }
                },
                "example": "<Invoice xmlns=\"urn:oasis:names:specification:ubl:schema:xsd:Invoice-2\" xmlns:cac=\"urn:oasis:names:specification:ubl:schema:xsd:CommonAggregateComponents-2\" xmlns:cbc=\"urn:oasis:names:specification:ubl:schema:xsd:CommonBasicComponents-2\">\n  <cbc:ProfileID>Profile 1</cbc:ProfileID>\n  <cbc:IssueDate>2024-01-15</cbc:IssueDate>\n  <cbc:DueDate>2024-02-15</cbc:DueDate>\n  <cac:LegalMonetaryTotal>\n    <cbc:PayableAmount currencyID=\"AUD\">729</cbc:PayableAmount>\n  </cac:LegalMonetaryTotal>\n</Invoice>"
              }
            }
          },
          "404": {
            "description": "Invoice not found or not yet transformed"
          },
          "500": {
            "description": "Unexpected system failure"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "SignupRequest": {
        "type": "object",
        "required": ["email", "password", "companyName"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "aaron@stashcorp.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          },
          "companyName": {
            "type": "string",
            "example": "Stash Corp"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "aaron@stashcorp.com"
          },
          "password": {
            "type": "string",
            "example": "password123"
          }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "userId": {
            "type": "string",
            "example": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8"
          },
          "email": {
            "type": "string",
            "example": "aaron@stashcorp.com"
          }
        }
      },
      "CreateInvoiceRequest": {
        "type": "object",
        "required": ["userId", "invoiceData"],
        "properties": {
          "userId": {
            "type": "string",
            "example": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8"
          },
          "invoiceData": {
            "type": "object",
            "required": [
              "ProfileID",
              "IssueDate",
              "DueDate",
              "OrderReference",
              "Supplier",
              "Customer",
              "LegalMonetaryTotal"
            ],
            "properties": {
              "ProfileID": {
                "type": "string",
                "example": "urn:fdc:peppol.eu:2017:poacc:billing:01:1.0"
              },
              "IssueDate": {
                "type": "string",
                "format": "date",
                "example": "2024-01-15"
              },
              "DueDate": {
                "type": "string",
                "format": "date",
                "example": "2024-02-15"
              },
              "OrderReference": {
                "type": "object",
                "required": ["ID"],
                "properties": {
                  "ID": {
                    "type": "string",
                    "example": "ORD-001"
                  }
                }
              },
              "Delivery": {
                "type": "object",
                "properties": {
                  "ActualDeliveryDate": {
                    "type": "string",
                    "format": "date",
                    "example": "2024-01-14"
                  },
                  "ActualDeliveryTime": {
                    "type": "string",
                    "example": "14:30:00"
                  }
                }
              },
              "PaymentMeans": {
                "type": "object",
                "required": [
                  "PaymentMeansCode",
                  "PaymentDueDate",
                  "PayeeFinancialAccount"
                ],
                "properties": {
                  "PaymentMeansCode": {
                    "type": "string",
                    "example": "30"
                  },
                  "PaymentDueDate": {
                    "type": "string",
                    "format": "date",
                    "example": "2024-02-15"
                  },
                  "PayeeFinancialAccount": {
                    "type": "object",
                    "required": ["ID", "Name", "Currency"],
                    "properties": {
                      "ID": {
                        "type": "string",
                        "example": "GB29NWBK60161331926819"
                      },
                      "Name": {
                        "type": "string",
                        "example": "Stash Corp"
                      },
                      "Currency": {
                        "type": "string",
                        "example": "AUD"
                      }
                    }
                  }
                }
              },
              "Supplier": {
                "type": "object",
                "required": ["Name", "ID"],
                "properties": {
                  "Name": {
                    "type": "string",
                    "example": "Stash Corp"
                  },
                  "ID": {
                    "type": "string",
                    "example": "SUP-001"
                  }
                }
              },
              "Customer": {
                "type": "object",
                "required": ["Name", "ID"],
                "properties": {
                  "Name": {
                    "type": "string",
                    "example": "Client Ltd"
                  },
                  "ID": {
                    "type": "string",
                    "example": "CUST-001"
                  }
                }
              },
              "LegalMonetaryTotal": {
                "type": "object",
                "required": [
                  "Currency",
                  "LineExtensionAmount",
                  "TaxExclusiveAmount",
                  "TaxInclusiveAmount",
                  "AllowanceTotalAmount",
                  "ChargeTotalAmount",
                  "PrepaidAmount",
                  "PayableAmount"
                ],
                "properties": {
                  "Currency": {
                    "type": "string",
                    "example": "AUD"
                  },
                  "LineExtensionAmount": {
                    "type": "number",
                    "example": 1436.5
                  },
                  "TaxExclusiveAmount": {
                    "type": "number",
                    "example": 1436.5
                  },
                  "TaxInclusiveAmount": {
                    "type": "number",
                    "example": 1729
                  },
                  "AllowanceTotalAmount": {
                    "type": "number",
                    "example": 100
                  },
                  "ChargeTotalAmount": {
                    "type": "number",
                    "example": 100
                  },
                  "PrepaidAmount": {
                    "type": "number",
                    "example": 1000
                  },
                  "PayableAmount": {
                    "type": "number",
                    "example": 729
                  }
                }
              }
            }
          }
        }
      },
      "CreateInvoiceResponse": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string",
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          },
          "status": {
            "type": "string",
            "example": "created"
          }
        }
      },
      "InvoiceResponse": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "string",
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          },
          "user_id": {
            "type": "string",
            "example": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8"
          },
          "status": {
            "type": "string",
            "example": "created"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-15T10:00:00.000Z"
          },
          "invoice_data": {
            "type": "object"
          }
        }
      },
      "InvoiceList": {
        "type": "object",
        "properties": {
          "invoices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvoiceResponse"
            }
          }
        }
      },
      "ValidateInvoiceResponse": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string",
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          },
          "valid": {
            "type": "boolean",
            "example": true
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": ["message"],
        "properties": {
          "message": {
            "type": "string",
            "example": "Missing required field: IssueDate"
          }
        }
      },
      "TransformInvoiceResponse": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string",
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          },
          "status": {
            "type": "string",
            "example": "transformed"
          },
          "invoiceXml": {
            "type": "string",
            "example": "<?xml version=\"1.0\" encoding=\"UTF-8\"?><Invoice>...</Invoice>"
          }
        }
      }
    }
  }
}
