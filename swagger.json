{
  "openapi": "3.0.0",
  "info": {
    "title": "Invoice Generator API",
    "version": "2.0.0",
    "description": "API for generating UBL XML invoices from structured input data. V2 routes include enhanced invoice data with PostalAddress, Contact, and DocumentCurrencyCode fields."
  },
  "servers": [
    {
      "url": "http://3.106.79.128:3000",
      "description": "Production server"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "tags": [
    {
      "name": "Authentication",
      "description": "User authentication and registration"
    },
    {
      "name": "Invoices V1",
      "description": "Original MVP invoice routes - maintained for backwards compatibility"
    },
    {
      "name": "Invoice Features",
      "description": "Additional invoice features - status management, download, email, and AI extraction"
    },
    {
      "name": "Invoices V2",
      "description": "Updated invoice routes with enhanced data structure including PostalAddress, Contact, and DocumentCurrencyCode"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/auth/signup": {
      "post": {
        "tags": ["Authentication"],
        "security": [],
        "summary": "Sign up",
        "description": "Creates a new user account and returns a JWT token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/SignupRequest" },
              "example": {
                "email": "aaron@stashcorp.com",
                "password": "password123",
                "companyName": "Stash Corp"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User successfully created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "400": {
            "description": "Email already in use or missing required fields"
          },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/auth/login": {
      "post": {
        "tags": ["Authentication"],
        "security": [],
        "summary": "Login",
        "description": "Logs in an existing user and returns a JWT token.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/LoginRequest" },
              "example": {
                "email": "aaron@stashcorp.com",
                "password": "password123"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AuthResponse" }
              }
            }
          },
          "401": { "description": "Invalid email or password" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/auth/user/{userId}": {
      "get": {
        "tags": ["Authentication"],
        "summary": "Get user",
        "description": "Retrieves a user's information by their unique ID.",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8"
          }
        ],
        "responses": {
          "200": {
            "description": "User retrieved successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserResponse" }
              }
            }
          },
          "404": { "description": "User not found" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/invoices": {
      "post": {
        "tags": ["Invoices V1"],
        "summary": "Create Invoice (V1)",
        "description": "Creates a new invoice using the original data structure. Maintained for backwards compatibility.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvoiceRequestV1"
              },
              "example": {
                "userId": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8",
                "invoiceData": {
                  "ProfileID": "urn:fdc:peppol.eu:2017:poacc:billing:01:1.0",
                  "IssueDate": "2024-01-15",
                  "DueDate": "2024-02-15",
                  "OrderReference": { "ID": "ORD-001" },
                  "Delivery": {
                    "ActualDeliveryDate": "2024-01-14",
                    "ActualDeliveryTime": "14:30:00"
                  },
                  "PaymentMeans": {
                    "PaymentMeansCode": "30",
                    "PaymentDueDate": "2024-02-15",
                    "PayeeFinancialAccount": {
                      "ID": "GB29NWBK60161331926819",
                      "Name": "Stash Corp",
                      "Currency": "AUD"
                    }
                  },
                  "Supplier": { "Name": "Stash Corp", "ID": "SUP-001" },
                  "Customer": { "Name": "Client Ltd", "ID": "CUST-001" },
                  "LegalMonetaryTotal": {
                    "Currency": "AUD",
                    "LineExtensionAmount": 1436.5,
                    "TaxExclusiveAmount": 1436.5,
                    "TaxInclusiveAmount": 1729,
                    "AllowanceTotalAmount": 100,
                    "ChargeTotalAmount": 100,
                    "PrepaidAmount": 1000,
                    "PayableAmount": 729
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invoice successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateInvoiceResponse"
                }
              }
            }
          },
          "400": { "description": "Missing required fields" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/invoices/{invoiceId}": {
      "get": {
        "tags": ["Invoices V1"],
        "summary": "Retrieve invoice",
        "description": "Retrieves a previously created invoice by its unique ID.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice retrieved",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/InvoiceResponse" }
              }
            }
          },
          "404": { "description": "Invoice not found" },
          "500": { "description": "System failure" }
        }
      },
      "delete": {
        "tags": ["Invoices V1"],
        "summary": "Delete invoice",
        "description": "Deletes an invoice and its associated XML file from S3.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice successfully deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "invoiceId": {
                      "type": "string",
                      "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
                    },
                    "status": { "type": "string", "example": "deleted" }
                  }
                }
              }
            }
          },
          "404": { "description": "Invoice not found" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/invoices/user/{userId}": {
      "get": {
        "tags": ["Invoices V1"],
        "summary": "Get invoices by user",
        "description": "Retrieves all invoices for a given user ID.",
        "parameters": [
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8"
          }
        ],
        "responses": {
          "200": {
            "description": "List of invoices",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/InvoiceResponse" }
                }
              }
            }
          },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/invoices/{invoiceId}/transform": {
      "post": {
        "tags": ["Invoices V1"],
        "summary": "Transform Invoice (V1)",
        "description": "Transforms invoice into UBL XML using original structure. Maintained for backwards compatibility. Use POST /v2/invoices/{invoiceId}/transform for updated XML output.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice successfully transformed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransformInvoiceResponse"
                }
              }
            }
          },
          "404": { "description": "Invoice not found" },
          "500": { "description": "Unexpected system failure" }
        }
      }
    },
    "/invoices/{invoiceId}/validate": {
      "post": {
        "tags": ["Invoices V1"],
        "summary": "Validate Invoice (V1)",
        "description": "Validates invoice against original rules including currency consistency between LegalMonetaryTotal and PayeeFinancialAccount. Maintained for backwards compatibility.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          }
        ],
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateInvoiceResponse"
                }
              }
            }
          },
          "400": { "description": "Invoice not yet transformed" },
          "404": { "description": "Invoice not found" },
          "500": { "description": "Unexpected system failure" }
        }
      }
    },
    "/invoices/{invoiceId}/status": {
      "put": {
        "tags": ["Invoice Features"],
        "summary": "Update invoice status",
        "description": "Updates the status of an invoice. Valid transitions: created → transformed → sent → paid/overdue → cancelled.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["status"],
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": [
                      "transformed",
                      "sent",
                      "paid",
                      "overdue",
                      "cancelled"
                    ],
                    "example": "paid"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Status updated successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "invoiceId": {
                      "type": "string",
                      "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
                    },
                    "status": { "type": "string", "example": "paid" }
                  }
                }
              }
            }
          },
          "400": { "description": "Invalid status transition" },
          "404": { "description": "Invoice not found" },
          "500": { "description": "Internal server error" }
        }
      }
    },
    "/invoices/{invoiceId}/download": {
      "get": {
        "tags": ["Invoice Features"],
        "summary": "Download invoice XML",
        "description": "Downloads the transformed UBL XML invoice document as a file.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          }
        ],
        "responses": {
          "200": {
            "description": "UBL XML invoice document",
            "content": {
              "application/xml": {
                "schema": {
                  "type": "object",
                  "xml": {
                    "name": "Invoice",
                    "namespace": "urn:oasis:names:specification:ubl:schema:xsd:Invoice-2"
                  }
                }
              }
            }
          },
          "404": { "description": "Invoice not found or not yet transformed" },
          "500": { "description": "Unexpected system failure" }
        }
      }
    },
    "/invoices/{invoiceId}/send-email": {
      "post": {
        "tags": ["Invoice Features"],
        "summary": "Send invoice email",
        "description": "Sends the invoice as a UBL XML attachment to the customer's email address.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          }
        ],
        "responses": {
          "200": {
            "description": "Email sent successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/SendEmailResponse" }
              }
            }
          },
          "400": { "description": "Missing or invalid invoice ID" },
          "404": { "description": "Invoice or user not found" },
          "500": { "description": "Failed to send email" }
        }
      }
    },
    "/invoices/extract": {
      "post": {
        "tags": ["Invoice Features"],
        "summary": "Extract invoice from file",
        "description": "Uploads a PDF or CSV file and extracts invoice data using AI.",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": { "type": "string", "format": "binary" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Invoice data extracted successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "invoiceData": { "type": "object" }
                  }
                }
              }
            }
          },
          "400": { "description": "No file uploaded or unsupported file type" },
          "500": { "description": "Extraction failed" }
        }
      }
    },
    "/v2/invoices/{invoiceId}/transform": {
      "post": {
        "tags": ["Invoices V2"],
        "summary": "Transform Invoice (V2)",
        "description": "Transforms invoice into UBL XML using enhanced structure with PostalAddress, Contact, and DocumentCurrencyCode.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice successfully transformed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransformInvoiceResponse"
                }
              }
            }
          },
          "404": { "description": "Invoice not found" },
          "500": { "description": "Unexpected system failure" }
        }
      }
    },
    "/v2/invoices/{invoiceId}/validate": {
      "post": {
        "tags": ["Invoices V2"],
        "summary": "Validate Invoice (V2)",
        "description": "Validates invoice against updated rules including DocumentCurrencyCode consistency check and PostalAddress requirements.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          }
        ],
        "responses": {
          "200": {
            "description": "Validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateInvoiceResponse"
                }
              }
            }
          },
          "400": { "description": "Invoice not yet transformed" },
          "404": { "description": "Invoice not found" },
          "500": { "description": "Unexpected system failure" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "SignupRequest": {
        "type": "object",
        "required": ["email", "password", "companyName"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "aaron@stashcorp.com"
          },
          "password": { "type": "string", "example": "password123" },
          "companyName": { "type": "string", "example": "Stash Corp" }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "aaron@stashcorp.com"
          },
          "password": { "type": "string", "example": "password123" }
        }
      },
      "AuthResponse": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
          },
          "userId": {
            "type": "string",
            "example": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8"
          },
          "email": { "type": "string", "example": "aaron@stashcorp.com" }
        }
      },
      "UserResponse": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "string",
            "example": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8"
          },
          "email": { "type": "string", "example": "aaron@stashcorp.com" },
          "companyName": { "type": "string", "example": "Stash Corp" },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-15T10:00:00.000Z"
          }
        }
      },
      "CreateInvoiceRequestV1": {
        "type": "object",
        "required": ["userId", "invoiceData"],
        "properties": {
          "userId": {
            "type": "string",
            "example": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8"
          },
          "invoiceData": {
            "type": "object",
            "required": [
              "ProfileID",
              "IssueDate",
              "DueDate",
              "OrderReference",
              "Supplier",
              "Customer",
              "LegalMonetaryTotal"
            ],
            "properties": {
              "ProfileID": {
                "type": "string",
                "example": "urn:fdc:peppol.eu:2017:poacc:billing:01:1.0"
              },
              "IssueDate": {
                "type": "string",
                "format": "date",
                "example": "2024-01-15"
              },
              "DueDate": {
                "type": "string",
                "format": "date",
                "example": "2024-02-15"
              },
              "OrderReference": {
                "type": "object",
                "required": ["ID"],
                "properties": {
                  "ID": { "type": "string", "example": "ORD-001" }
                }
              },
              "Delivery": {
                "type": "object",
                "properties": {
                  "ActualDeliveryDate": {
                    "type": "string",
                    "format": "date",
                    "example": "2024-01-14"
                  },
                  "ActualDeliveryTime": {
                    "type": "string",
                    "example": "14:30:00"
                  }
                }
              },
              "PaymentMeans": {
                "type": "object",
                "properties": {
                  "PaymentMeansCode": { "type": "string", "example": "30" },
                  "PaymentDueDate": {
                    "type": "string",
                    "format": "date",
                    "example": "2024-02-15"
                  },
                  "PayeeFinancialAccount": {
                    "type": "object",
                    "required": ["ID", "Name", "Currency"],
                    "properties": {
                      "ID": {
                        "type": "string",
                        "example": "GB29NWBK60161331926819"
                      },
                      "Name": { "type": "string", "example": "Stash Corp" },
                      "Currency": { "type": "string", "example": "AUD" }
                    }
                  }
                }
              },
              "Supplier": {
                "type": "object",
                "required": ["Name"],
                "properties": {
                  "Name": { "type": "string", "example": "Stash Corp" },
                  "ID": { "type": "string", "example": "SUP-001" }
                }
              },
              "Customer": {
                "type": "object",
                "required": ["Name"],
                "properties": {
                  "Name": { "type": "string", "example": "Client Ltd" },
                  "ID": { "type": "string", "example": "CUST-001" },
                  "Email": {
                    "type": "string",
                    "format": "email",
                    "example": "client@example.com"
                  }
                }
              },
              "LegalMonetaryTotal": {
                "type": "object",
                "required": [
                  "Currency",
                  "LineExtensionAmount",
                  "TaxExclusiveAmount",
                  "TaxInclusiveAmount",
                  "PayableAmount"
                ],
                "properties": {
                  "Currency": { "type": "string", "example": "AUD" },
                  "LineExtensionAmount": {
                    "type": "number",
                    "example": 1436.5
                  },
                  "TaxExclusiveAmount": { "type": "number", "example": 1436.5 },
                  "TaxInclusiveAmount": { "type": "number", "example": 1729 },
                  "AllowanceTotalAmount": { "type": "number", "example": 100 },
                  "ChargeTotalAmount": { "type": "number", "example": 100 },
                  "PrepaidAmount": { "type": "number", "example": 1000 },
                  "PayableAmount": { "type": "number", "example": 729 }
                }
              }
            }
          }
        }
      },
      "CreateInvoiceResponse": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string",
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          },
          "status": { "type": "string", "example": "created" }
        }
      },
      "InvoiceResponse": {
        "type": "object",
        "properties": {
          "ID": {
            "type": "string",
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          },
          "user_id": {
            "type": "string",
            "example": "18eebbc2-8162-4bdd-b272-dd47dc81e7a8"
          },
          "status": { "type": "string", "example": "created" },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2024-01-15T10:00:00.000Z"
          },
          "invoice_data": { "type": "object" }
        }
      },
      "ValidateInvoiceResponse": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string",
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          },
          "valid": { "type": "boolean", "example": true },
          "errors": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ValidationError" }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "message": {
            "type": "string",
            "example": "Missing required field: IssueDate"
          }
        }
      },
      "TransformInvoiceResponse": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string",
            "example": "97c02b73-3b44-42a2-97b7-c9427d150fac"
          },
          "status": { "type": "string", "example": "transformed" },
          "invoiceXml": {
            "type": "string",
