{
  "openapi": "3.0.0",
  "info": {
    "title": "Invoice Generator API",
    "version": "1.0.0",
    "description": "API for generating UBL XML invoices from structured input data"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "paths": {
    "/health": {
      "get": {
        "summary": "Health check",
        "description": "Returns service status",
        "responses": {
          "200": {
            "description": "Service is running"
          }
        }
      }
    },
    "/invoices": {
      "post": {
        "summary": "Create Invoice",
        "description": "Creates a new structured invoice from input data",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvoiceRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Invoice successfully created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Missing required fields"
          },
          "404": {
            "description": "Related order or customer not found"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      },
      "get": {
        "summary": "List invoices",
        "description": "Retrieve invoices with optional filtering",
        "parameters": [
          {
            "name": "customerId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "orderId",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "status",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "List of invoices",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceList"
                }
              }
            }
          }
        }
      }
    },
    "/invoices/{invoiceId}": {
      "get": {
        "summary": "Retrieve invoice",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice retrieved",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceResponse"
                }
              }
            }
          },
          "404": {
            "description": "Invoice not found"
          },
          "500": {
            "description": "System failure"
          }
        }
      },
      "put": {
        "summary": "Update invoice",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateInvoiceRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated invoice",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InvoiceResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid input"
          },
          "404": {
            "description": "Invoice not found"
          },
          "500": {
            "description": "System failure"
          }
        }
      },
      "delete": {
        "summary": "Delete invoice",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Invoice deleted"
          },
          "404": {
            "description": "Invoice not found"
          },
          "500": {
            "description": "System failure"
          }
        }
      }
    },
    "/invoices/{invoiceId}/validate": {
      "post": {
        "summary": "Validate invoice",
        "description": "Validates the generated UBL invoice document against the required UBL validation rules and schema to check if it is compliant.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the invoice"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice validation result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidateInvoiceResponse"
                }
              }
            }
          },
          "404": {
            "description": "InvoiceId does not exist"
          },
          "500": {
            "description": "Unexpected system failure"
          }
        }
      }
    },
    "/invoices/{invoiceId}/transform": {
      "post": {
        "summary": "Transform invoice",
        "description": "Transforms a previously created structured invoice into a UBL XML invoice document.",
        "parameters": [
          {
            "name": "invoiceId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Unique identifier for the invoice"
          }
        ],
        "responses": {
          "200": {
            "description": "Invoice successfully transformed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TransformInvoiceResponse"
                }
              }
            }
          },
          "404": {
            "description": "InvoiceId does not exist"
          },
          "400": {
            "description": "Invoice data cannot be transformed into UBL XML"
          },
          "500": {
            "description": "Unexpected system failure"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreateInvoiceRequest": {
        "type": "object",
        "required": [
          "ProfileID",
          "IssueDate",
          "DueDate",
          "OrderReference",
          "Supplier",
          "Customer",
          "LegalMonetaryTotal"
        ],
        "properties": {
          "ProfileID": {
            "type": "string"
          },
          "IssueDate": {
            "type": "string",
            "format": "date"
          },
          "DueDate": {
            "type": "string",
            "format": "date"
          },
          "OrderReference": {
            "type": "object",
            "required": [
              "ID"
            ],
            "properties": {
              "ID": {
                "type": "string"
              }
            }
          },
          "Delivery": {
            "type": "object",
            "properties": {
              "ActualDeliveryDate": {
                "type": "string",
                "format": "date"
              },
              "ActualDeliveryTime": {
                "type": "string"
              }
            }
          },
          "PaymentMeans": {
            "type": "object",
            "required": [
              "PaymentMeansCode",
              "PaymentDueDate",
              "PayeeFinancialAccount"
            ],
            "properties": {
              "PaymentMeansCode": {
                "type": "string"
              },
              "PaymentDueDate": {
                "type": "string",
                "format": "date"
              },
              "PayeeFinancialAccount": {
                "type": "object",
                "required": [
                  "ID",
                  "Name",
                  "Currency"
                ],
                "properties": {
                  "ID": {
                    "type": "string"
                  },
                  "Name": {
                    "type": "string"
                  },
                  "Currency": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "Supplier": {
            "type": "object",
            "required": [
              "Name",
              "ID"
            ],
            "properties": {
              "Name": {
                "type": "string"
              },
              "ID": {
                "type": "string"
              }
            }
          },
          "Customer": {
            "type": "object",
            "required": [
              "Name",
              "ID"
            ],
            "properties": {
              "Name": {
                "type": "string"
              },
              "ID": {
                "type": "string"
              }
            }
          },
          "LegalMonetaryTotal": {
            "type": "object",
            "required": [
              "Currency",
              "LineExtensionAmount",
              "TaxExclusiveAmount",
              "TaxInclusiveAmount",
              "AllowanceTotalAmount",
              "ChargeTotalAmount",
              "PrepaidAmount",
              "PayableAmount"
            ],
            "properties": {
              "Currency": {
                "type": "string"
              },
              "LineExtensionAmount": {
                "type": "number"
              },
              "TaxExclusiveAmount": {
                "type": "number"
              },
              "TaxInclusiveAmount": {
                "type": "number"
              },
              "AllowanceTotalAmount": {
                "type": "number"
              },
              "ChargeTotalAmount": {
                "type": "number"
              },
              "PrepaidAmount": {
                "type": "number"
              },
              "PayableAmount": {
                "type": "number"
              }
            }
          }
        }
      },
      "InvoiceResponse": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "totalAmount": {
            "type": "number"
          },
          "invoiceXml": {
            "type": "string"
          }
        }
      },
      "InvoiceList": {
        "type": "object",
        "properties": {
          "invoices": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InvoiceResponse"
            }
          }
        }
      },
      "ValidateInvoiceResponse": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string"
          },
          "valid": {
            "type": "boolean"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            }
          }
        }
      },
      "ValidationError": {
        "type": "object",
        "required": [
          "message"
        ],
        "properties": {
          "message": {
            "type": "string"
          }
        }
      },
      "TransformInvoiceResponse": {
        "type": "object",
        "properties": {
          "invoiceId": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "invoiceXML": {
            "type": "string"
          }
        }
      }
    }
  }
}